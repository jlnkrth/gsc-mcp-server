# Google Cloud OAuth 2.0 Desktop client credentials
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret

# Optional: where to store OAuth tokens (default: ~/.config/gsc-mcp/tokens.json)
# GSC_TOKEN_PATH=/Users/you/.config/gsc-mcp/tokens.json

# Optional: pre-fill Google sign-in email in the OAuth browser flow
# GOOGLE_LOGIN_HINT=you@example.com
